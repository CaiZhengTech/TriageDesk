# Local dev: set TRIAGEDESK_ENV_FILE to absolute path of a credentials env file
# (e.g. via `setx TRIAGEDESK_ENV_FILE "<path>"` on Windows). CI/Railway set real env vars.
# TRIAGEDESK_ENV_FILE=

# Neon dev branch (SQLAlchemy rewrites the driver prefix automatically)
DATABASE_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
# Neon test branch — integration tests + CI
TEST_DATABASE_URL=postgresql://user:pass@ep-yyy.aws.neon.tech/neondb?sslmode=require
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
# Per-run cost cap in USD; breach or uncomputable cost => escalate (fail closed)
COST_CAP_USD=0.10
# Review-queue admin auth (POST /api/review/{run_id}); unset => 503, fail closed
ADMIN_TOKEN=
# Comma-separated list of allowed cross-origin console URLs (e.g. the Vercel deploy
# URL). Empty => no CORSMiddleware is registered at all (fail closed, no cross-origin
# access), never a wildcard.
CORS_ORIGINS=
# Emit one-line JSON log records ({"ts","level","logger","msg"}) instead of stdlib
# default formatting.
LOG_JSON=false
# Demo abuse protection (POST /api/demo/run, GET /api/demo/pool): daily USD cap
# across all demo runs (summed for the current UTC day, pre-check + fail closed)
# and the per-IP hourly request limit (in-memory fixed window, single instance only).
DEMO_DAILY_CAP_USD=1.00
DEMO_RATE_LIMIT_PER_HOUR=5
